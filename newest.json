[{"short_id":"prer9l","created_at":"2026-05-19T07:53:39.000-05:00","title":"Software's Centaur Era","url":"https://twitchard.github.io/posts/2026-05-18-softwares-centaur-era.html","score":2,"flags":0,"comment_count":0,"description":"","description_plain":"","submitter_user":"carlana","user_is_author":false,"tags":["vibecoding"],"short_id_url":"https://lobste.rs/s/prer9l","comments_url":"https://lobste.rs/s/prer9l/software_s_centaur_era"},{"short_id":"hvsk8u","created_at":"2026-05-19T07:53:12.000-05:00","title":"A sparse, compressed bitmap index in C.  Is it better than Roaring Bitmaps?","url":"https://codeberg.org/gregburd/sparsemap","score":-1,"flags":2,"comment_count":0,"description":"\u003cp\u003eThis is an implementation of a sparse, compressed bitmap index. In the best case, it can store 2048 bits in just 8 bytes. In the worst case, it stores the 2048 bits uncompressed and requires an additional 8 bytes of overhead.  It compares favorably against RoaringBitmaps and other competition in the space, but is it better?\u003c/p\u003e\n","description_plain":"This is an implementation of a sparse, compressed bitmap index. In the best case, it can store 2048 bits in just 8 bytes. In the worst case, it stores the 2048 bits uncompressed and requires an additional 8 bytes of overhead.  It compares favorably against RoaringBitmaps and other competition in the space, but is it better?","submitter_user":"gregburd","user_is_author":true,"tags":["c","programming"],"short_id_url":"https://lobste.rs/s/hvsk8u","comments_url":"https://lobste.rs/s/hvsk8u/sparse_compressed_bitmap_index_c_is_it"},{"short_id":"meukqk","created_at":"2026-05-19T07:48:27.000-05:00","title":"A self-balancing skip-list (aka \"splay-list\") library in C","url":"https://codeberg.org/gregburd/skiplist","score":-1,"flags":3,"comment_count":0,"description":"\u003cp\u003eA header-only C library implementing a concurrent, lock-free skip-list (specifically, a splay-list: a skip-list with optional adaptive rebalancing). The entire implementation lives in preprocessor macros in include/sl.h that generate type-specific code at compile time, similar to C++ templates.\u003c/p\u003e\n","description_plain":"A header-only C library implementing a concurrent, lock-free skip-list (specifically, a splay-list: a skip-list with optional adaptive rebalancing). The entire implementation lives in preprocessor macros in include/sl.h that generate type-specific code at compile time, similar to C++ templates.","submitter_user":"gregburd","user_is_author":true,"tags":["c","programming"],"short_id_url":"https://lobste.rs/s/meukqk","comments_url":"https://lobste.rs/s/meukqk/self_balancing_skip_list_aka_splay_list"},{"short_id":"lz0eld","created_at":"2026-05-19T07:44:00.000-05:00","title":"Lime, a parser generator that can merge grammars at runtime","url":"https://codeberg.org/gregburd/lime","score":-2,"flags":3,"comment_count":0,"description":"\u003cp\u003eLime is a new parser generator similar to Yacc, Bison, ANTLR, etc. except it's faster and has the ability to merge or remove grammars at runtime. See the 'calc' example that starts knowing + and - but then adds ^ for exponent, then adds ^ again for bitwise or. That can't work, right?\u003c/p\u003e\n","description_plain":"Lime is a new parser generator similar to Yacc, Bison, ANTLR, etc. except it's faster and has the ability to merge or remove grammars at runtime. See the 'calc' example that starts knowing + and - but then adds ^ for exponent, then adds ^ again for bitwise or. That can't work, right?","submitter_user":"gregburd","user_is_author":true,"tags":["c","compilers"],"short_id_url":"https://lobste.rs/s/lz0eld","comments_url":"https://lobste.rs/s/lz0eld/lime_parser_generator_can_merge_grammars"},{"short_id":"zsjasr","created_at":"2026-05-19T07:29:28.000-05:00","title":"My domain got abused on Github Pages","url":"https://meertens.dev/blog/github-enables-domain-abuse/","score":1,"flags":0,"comment_count":0,"description":"","description_pla